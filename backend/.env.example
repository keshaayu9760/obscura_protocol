PORT=3001
ALEO_ENDPOINT=https://api.explorer.provable.com/v1
# Comma-separated origins for CORS (e.g. https://veil-strike.netlify.app,http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
# Private key of the market resolver/admin (same address used to create markets)
# Required for auto-resolution of markets (close → resolve → finalize)
RESOLVER_PRIVATE_KEY=
