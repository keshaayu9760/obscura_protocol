PORT=3001
ALEO_ENDPOINT=https://api.explorer.provable.com/v1
DATABASE_URL=postgresql://obscura_app:change_me@127.0.0.1:5433/obscura_protocol
# Optional admin connection used by `npm run db:bootstrap` to create the database if missing.
# In local WSL setups this usually points at the default `postgres` database on the WSL-exposed port.
DATABASE_ADMIN_URL=postgresql://postgres:change_me@127.0.0.1:5433/postgres
DATABASE_SSL_MODE=disable
ALEO_PROGRAM_ID=obscura_v2_0.aleo
ALEO_PROGRAM_ID_CX=obscura_v2_0_cx.aleo
ALEO_PROGRAM_ID_SD=obscura_v2_0_sd.aleo
ALEO_DEPLOY_TXID=
ALEO_DEPLOY_TXID_CX=
ALEO_DEPLOY_TXID_SD=
# Comma-separated origins for CORS (e.g. https://obscura-protocol.netlify.app,http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
# Private key of the market resolver/admin (same address used to create markets)
# Required for auto-resolution of markets (close → resolve → finalize)
RESOLVER_PRIVATE_KEY=
# Provable delegated proving API (register at https://api.provable.com/consumers)
PROVABLE_API_KEY=
PROVABLE_CONSUMER_ID=
# Round bot settings
ROUND_BOT_ENABLED=true
ROUND_DURATION_MINUTES=15
ROUND_INITIAL_LIQUIDITY=1000000
